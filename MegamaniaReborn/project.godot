[application]
config/name="MegaMania Reborn"
config/description="A modern arcade shooter inspired by the classics"
run/main_scene="res://scenes/main/Main.tscn"

[autoload]
EventBus="*res://scripts/core/EventBus.gd"
GameManager="*res://scripts/core/GameManager.gd"
ScoreManager="*res://scripts/core/ScoreManager.gd"
PoolManager="*res://scripts/core/PoolManager.gd"
AudioManager="*res://scripts/core/AudioManager.gd"
WaveManager="*res://scripts/core/WaveManager.gd"
SaveManager="*res://scripts/utils/SaveManager.gd"

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/stretch/aspect="keep"

[physics]
common/physics_ticks_per_second=60

[rendering]
renderer/rendering_method="forward_plus"
environment/defaults/default_clear_color=Color(0.02, 0.02, 0.06, 1)

[layer_names]
2d_physics/layer_1="player"
2d_physics/layer_2="player_bullet"
2d_physics/layer_3="enemy"
2d_physics/layer_4="enemy_bullet"
2d_physics/layer_5="pickup"


{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/qwen/qwen3-235b-a22b",
  "small_model": "openrouter/meta-llama/llama-3.3-70b-instruct:free",
  "default_agent": "build",
  "command": {
    "deploy": {
      "description": "Deploy da landing page via FTP para Hostinger",
      "template": "Execute o deploy completo da landing page via FTP para a Hostinger. Use as configurações de deploy disponíveis e ferramentas necessárias.",
      "agent": "build"
    },
    "preview": {
      "description": "Abre o site no navegador via Playwright",
      "template": "Abra o site no navegador usando Playwright para visualizar a landing page.",
      "agent": "build"
    },
    "css-agent": {
      "description": "Chama o subagente especialista em CSS do IE Embelleze",
      "template": "Delegue ao subagente especialista em CSS 'designer-css' para ajustar layout e estilos. Apresente a tarefa claramente para o subagente.",
      "agent": "designer-css"
    }
  },
  "lsp": true,
  "snapshot": true,
  "agent": {
    "security-auditor": {
      "description": "Auditor de segurança - identifica vulnerabilidades",
      "mode": "subagent",
"model": "openrouter/qwen/qwen3-235b-a22b",
      "temperature": 0.1,
      "color": "#00ff41",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "grep *": "allow",
          "git diff *": "allow",
          "git log*": "allow"
        },
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "wp-admin": {
      "description": "Gerencia o WordPress do Instituto Embelleze Foz",
      "mode": "subagent",
      "color": "#3858e9",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "grep *": "allow"
        },
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "designer-css": {
      "description": "Especialista em CSS do Instituto Embelleze Foz",
      "mode": "subagent",
      "color": "#d6b06a",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "websearch": "deny"
      }
    }
  },
  "plugin": [
    "opencode-gemini-auth",
    "opencode-mem",
    "opencode-command-inject",
    "opencode-background-agents",
    "opencode-cost-guard"
  ],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "llama3.1:8b-instruct-q4_K_M": {
          "name": "Llama 3.1 8B (local)"
        },
        "qwen3:8b": {
          "name": "Qwen3 8B (local)",
          "limit": {
            "context": 32000,
            "output": 8192
          }
        },
        "gemma4:12b": {
          "name": "Gemma 4 12B (local)",
          "limit": {
            "context": 32000,
            "output": 8192
          }
        }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp"
      ],
      "enabled": true,
      "timeout": 10000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "timeout": 30000
    },
    "git": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "mcp_server_git"
      ],
      "enabled": true,
      "timeout": 10000
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "cmd",
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "wordpress": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@automattic/mcp-wordpress-remote@latest"
      ],
      "enabled": false,
      "timeout": 30000,
      "env": {
        "WP_API_URL": "https://institutoembellezefoz.com.br/",
        "JWT_TOKEN": ""
      }
    }
  }
}
